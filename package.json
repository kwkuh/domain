{
  "name": "@kwkuh/domainer",
  "version": "0.1.0",
  "description": "Domainer — open-source Telegram bot for domain portfolio management. Zero paid APIs. Self-hosted.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "domainer": "./dist/index.js",
    "domainer-cli": "./dist/cli.js",
    "domainer-server": "./dist/server.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:server": "node dist/server.js",
    "cli": "node dist/cli.js",
    "dev": "tsx watch src/index.ts",
    "dev:server": "tsx watch src/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.5.0",
    "dotenv": "^16.4.5",
    "grammy": "^1.30.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^25.7.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "telegram",
    "bot",
    "domain",
    "portfolio",
    "whois",
    "rdap",
    "domainer",
    "domain-investor",
    "self-hosted"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kwkuh/domainer"
  }
}
