# Telegram bot token from @BotFather
BOT_TOKEN=

# Optional: comma-separated Telegram user IDs allowed to use the bot.
# Leave empty to allow everyone (NOT recommended for public deployment).
ALLOWED_USERS=

# Where to store the SQLite database. Default: ./data/domainer.sqlite
DATA_DIR=./data

# Cron tick interval in minutes (RDAP refresh, expiry alerts). Default: 60
TICK_MINUTES=60

# Optional: override RDAP bootstrap URL. Default: https://rdap.org
RDAP_BOOTSTRAP=https://rdap.org
